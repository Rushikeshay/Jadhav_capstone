<div class="container py-4">

  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="h4 fw-bold mb-0">
      <i class="fa-solid fa-location-dot me-2 text-primary"></i>All Activities
    </h1>
    <a href="/trips" class="btn btn-outline-secondary btn-sm">
      <i class="fa-solid fa-arrow-left me-1"></i>Home
    </a>
  </div>

  <% if @list_of_activities.any? %>
    <div class="d-flex flex-column gap-2">
      <% @list_of_activities.each do |activity| %>
        <% day  = activity.day %>
        <% trip = day&.trip %>
        <a href="/activities/<%= activity.id %>" class="text-decoration-none">
          <div class="card border-0 shadow-sm">
            <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between">
              <div class="overflow-hidden">
                <p class="mb-0 fw-semibold small text-dark text-truncate">
                  <%= activity.name.presence || "Activity ##{activity.id}" %>
                </p>
                <p class="mb-0 text-muted" style="font-size:0.72rem;">
                  <% if trip %>
                    <i class="fa-solid fa-plane me-1"></i><%= trip.title.presence || "Trip ##{trip.id}" %>
                    &nbsp;&middot;&nbsp;
                  <% end %>
                  <% if day&.date %>
                    <i class="fa-regular fa-calendar me-1"></i><%= day.date.strftime("%b %-d, %Y") %>
                  <% end %>
                </p>
              </div>
              <i class="fa-solid fa-chevron-right text-muted ms-3" style="font-size:0.75rem;flex-shrink:0;"></i>
            </div>
          </div>
        </a>
      <% end %>
    </div>
  <% else %>
    <div class="app-empty">
      <i class="fa-solid fa-location-dot fa-3x"></i>
      <p>No activities yet.</p>
      <a href="/trips" class="btn btn-primary btn-sm">Go to your trips</a>
    </div>
  <% end %>

</div>
