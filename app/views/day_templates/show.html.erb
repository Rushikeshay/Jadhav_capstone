<%# ===== HERO HEADER ===== %>
<% hero_pic = @the_day.cover_image.present? ? @the_day.cover_image.url : @the_day.activities.find { |a| a.picture.present? }&.picture&.url %>
<div class="position-relative mb-4" style="height:200px;overflow:hidden;background:#1a1a2e;">
  <% if hero_pic %>
    <img src="<%= hero_pic %>" alt="<%= @the_day.title %>"
         style="width:100%;height:100%;object-fit:cover;opacity:0.55;">
  <% else %>
    <div class="w-100 h-100 d-flex align-items-center justify-content-center">
      <i class="fa-regular fa-calendar fa-4x text-white opacity-25"></i>
    </div>
  <% end %>

  <%# Back button %>
  <div class="position-absolute top-0 start-0 p-3">
    <a href="/trips/<%= @the_day.trip_id %>" class="btn btn-sm btn-light bg-white bg-opacity-75">
      <i class="fa-solid fa-arrow-left me-1"></i>Back to Trip
    </a>
  </div>

  <%# Edit + Delete buttons %>
  <div class="position-absolute top-0 end-0 p-3 d-flex gap-2">
    <button class="btn btn-sm btn-light bg-white bg-opacity-75"
            type="button" data-bs-toggle="collapse" data-bs-target="#editDayForm"
            aria-expanded="false">
      <i class="fa-solid fa-pen me-1"></i>Edit
    </button>
    <a href="/delete_day/<%= @the_day.id %>" class="btn btn-sm btn-danger"
       data-turbo-method="delete"
       onclick="return confirm('Delete this day?')">
      <i class="fa-solid fa-trash"></i>
    </a>
  </div>

  <%# Day title + date %>
  <div class="position-absolute bottom-0 start-0 p-3 text-white">
    <h1 class="fw-bold mb-0" style="text-shadow:0 1px 4px rgba(0,0,0,.6);">
      <%= @the_day.title.presence || "Day ##{@the_day.id}" %>
    </h1>
    <p class="mb-0 small opacity-75">
      <i class="fa-regular fa-calendar me-1"></i><%= @the_day.date&.strftime("%B %-d, %Y") %>
    </p>
  </div>
</div>

<div class="container pb-5">
  <%# Collapsed edit form %>
  <div class="collapse mb-4" id="editDayForm">
    <div class="card border-0 shadow-sm">
      <div class="card-body py-3">
        <form action="/modify_day/<%= @the_day.id %>" method="post" enctype="multipart/form-data" class="row g-2 align-items-end">
          <input type="hidden" name="query_trip_id" value="<%= @the_day.trip_id %>">
          <div class="col-auto">
            <label class="form-label small fw-semibold mb-1">Date</label>
            <input type="date" name="query_date" class="form-control form-control-sm"
                   value="<%= @the_day.date&.strftime("%Y-%m-%d") %>" required>
          </div>
          <div class="col">
            <label class="form-label small fw-semibold mb-1">
              Title <span class="text-muted fw-normal">(optional)</span>
            </label>
            <input type="text" name="query_title" class="form-control form-control-sm"
                   value="<%= @the_day.title %>" placeholder="e.g. Arrival Day, Beach Day...">
          </div>
          <div class="col-12">
            <label class="form-label small fw-semibold mb-1">
              Hero photo <span class="text-muted fw-normal">(overrides auto-selected activity photo)</span>
            </label>
            <% if @the_day.cover_image.present? %>
              <img src="<%= @the_day.cover_image.url %>" class="d-block rounded mb-1"
                   style="height:60px;object-fit:cover;width:100%;" alt="Current hero">
            <% end %>
            <input type="file" name="query_cover_image" class="form-control form-control-sm" accept="image/*">
          </div>
          <div class="col-auto">
            <button type="submit" class="btn btn-success btn-sm">
              <i class="fa-solid fa-floppy-disk me-1"></i>Save
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <%# Left Column: Activities List & Add Form %>
    <div class="col-lg-7">
      <h2 class="h4 mb-3">Activities</h2>

      <% if @the_day.activities.any? %>
        <div class="row g-3">
          <% @the_day.activities.each do |activity| %>
            <div class="col-md-6">
              <div class="card h-100 shadow-sm">
                <% if activity.picture.present? %>
                  <img src="<%= activity.picture.url %>" class="card-img-top"
                       style="height: 200px; object-fit: cover;" alt="<%= activity.name %>">
                <% else %>
                  <div class="bg-light text-center py-5 border-bottom">
                    <i class="fa-regular fa-image fa-3x text-muted"></i>
                  </div>
                <% end %>

                <div class="card-body">
                  <h5 class="card-title">
                    <a href="/activities/<%= activity.id %>" class="text-decoration-none text-primary">
                      <%= activity.name %>
                    </a>
                  </h5>
                  <% if activity.notes.present? %>
                    <p class="card-text text-muted small"><%= activity.notes %></p>
                  <% end %>
                </div>

                <% if activity.address.present? %>
                  <div class="card-footer bg-white border-top-0">
                    <small class="text-secondary">
                      <i class="fa-solid fa-location-dot me-1"></i><%= activity.address %>
                    </small>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-muted">No activities added yet.</p>
      <% end %>

      <hr class="my-5">

      <h3 class="h5 mb-3">Add a New Activity</h3>
      <form action="/insert_activity" method="post" enctype="multipart/form-data">
        <input type="hidden" name="query_day_id" value="<%= @the_day.id %>">

        <div class="mb-3">
          <label for="name_box" class="form-label fw-bold">Activity Name</label>
          <input type="text" id="name_box" name="query_name"
                 class="form-control" placeholder="e.g. Eiffel Tower Visit" required>
        </div>

        <div class="mb-3">
          <label for="address_box" class="form-label fw-bold">Address / Location</label>
          <input type="text" id="address_box" name="query_address"
                 class="form-control" placeholder="123 Street Name">
        </div>

        <div class="mb-3">
          <label for="notes_box" class="form-label fw-bold">Notes</label>
          <textarea id="notes_box" name="query_notes" rows="3"
                    class="form-control" placeholder="Don't forget the tickets!"></textarea>
        </div>

        <div class="mb-3">
          <label for="picture_box" class="form-label fw-bold">Upload Picture</label>
          <input type="file" id="picture_box" name="query_picture" class="form-control">
        </div>

        <button type="submit" class="btn btn-success">
          <i class="fa-solid fa-plus"></i> Add Activity
        </button>
      </form>
    </div>

    <%# Right Column: Map & Journal %>
    <div class="col-lg-5">
      <%# Map Section %>
      <h3 class="h5 mb-3">Map</h3>
      <div
        class="rounded border mb-4"
        style="height: 400px;"
        data-controller="google-map"
        data-google-map-markers-value="<%= map_markers_json(@the_day.activities) %>"
        data-google-map-zoom-value="12">
      </div>

      <%# Journal Section %>
      <% day_journals = Journal.where(day_id: @the_day.id, user_id: current_user.id).order(:created_at) %>
      <% pending_journal = day_journals.find { |j| j.response.blank? } %>
      <% completed_journals = day_journals.select { |j| j.response.present? } %>

      <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
          <h3 class="h5 mb-0">Daily Reflection</h3>
        </div>
        <div class="card-body">
          <p class="text-muted small mb-3">Let AI analyze your day and help you reflect.</p>
          <form action="/insert_journal" method="post">
            <input type="hidden" name="query_day_id" value="<%= @the_day.id %>">
            <div class="d-grid">
              <button class="btn btn-outline-primary btn-sm">
                <i class="fa-solid fa-robot me-2"></i>Generate Questions
              </button>
            </div>
          </form>

          <% if pending_journal %>
            <hr class="my-3">
            <p class="fw-bold mb-2 small text-primary">Reflect on these:</p>
            <ul class="ps-3 mb-3 small">
              <% pending_journal.ai_generated_questions.split("|").each do |question| %>
                <li class="mb-2"><em><%= question %></em></li>
              <% end %>
            </ul>
            <form action="/modify_journal/<%= pending_journal.id %>" method="post">
              <input type="hidden" name="query_day_id" value="<%= @the_day.id %>">
              <div class="mb-3">
                <textarea name="query_response" class="form-control" rows="6"
                          placeholder="Your thoughts..."></textarea>
              </div>
              <div class="d-grid">
                <button class="btn btn-success btn-sm">Save Entry</button>
              </div>
            </form>
          <% end %>
        </div>
      </div>

      <%# Completed journal entry boxes %>
      <% completed_journals.reverse_each do |journal| %>
        <div class="card shadow-sm mt-3">
          <div class="card-header bg-light py-2 d-flex align-items-center gap-2">
            <i class="fa-regular fa-pen-to-square text-muted"></i>
            <span class="small text-muted fw-semibold">Journal Entry</span>
          </div>
          <div class="card-body">
            <ul class="ps-3 mb-3 small text-muted">
              <% journal.ai_generated_questions.split("|").each do |q| %>
                <li class="mb-1"><em><%= q %></em></li>
              <% end %>
            </ul>
            <p class="mb-0 small" style="white-space:pre-wrap;"><%= journal.response %></p>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>
