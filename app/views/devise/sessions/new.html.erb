<div class="container">
  <div class="app-auth-card">
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <h2 class="h4 fw-bold mb-4">
          <i class="fa-solid fa-right-to-bracket me-2 text-primary"></i>Sign In
        </h2>

        <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="form-inputs">
            <%= f.input :email,
                        required: false,
                        autofocus: true,
                        input_html: { autocomplete: "email", class: "form-control" } %>
            <%= f.input :password,
                        required: false,
                        input_html: { autocomplete: "current-password", class: "form-control" } %>
            <%= f.input :remember_me, as: :boolean if devise_mapping.rememberable? %>
          </div>

          <div class="d-grid mt-3">
            <%= f.button :submit, "Sign In", class: "btn btn-primary" %>
          </div>
        <% end %>

        <div class="mt-3 text-center small">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>
