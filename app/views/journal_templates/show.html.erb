<div class="container py-4" style="max-width:720px;">

  <%# ===== Header ===== %>
  <div class="d-flex align-items-center justify-content-between mb-4">
    <a href="/days/<%= @the_journal.day_id %>" class="btn btn-outline-secondary btn-sm">
      <i class="fa-solid fa-arrow-left me-1"></i>Back to Day
    </a>
    <a href="/delete_journal/<%= @the_journal.id %>"
       class="btn btn-outline-danger btn-sm"
       data-turbo-method="delete"
       onclick="return confirm('Delete this journal entry?')">
      <i class="fa-solid fa-trash me-1"></i>Delete
    </a>
  </div>

  <%# ===== Title / Meta ===== %>
  <div class="mb-4">
    <h1 class="h4 fw-bold mb-1">
      <i class="fa-solid fa-book me-2 text-primary"></i>Journal Entry
    </h1>
    <p class="text-muted small mb-0">
      <% trip = @the_journal.day&.trip %>
      <% day  = @the_journal.day %>
      <% if trip %>
        <i class="fa-solid fa-plane me-1"></i><%= trip.title.presence || "Trip ##{trip.id}" %>
        &nbsp;&middot;&nbsp;
      <% end %>
      <% if day&.date %>
        <i class="fa-regular fa-calendar me-1"></i><%= day.date.strftime("%A, %B %d, %Y") %>
      <% elsif day %>
        <%= day.name.presence || "Day ##{day.id}" %>
      <% end %>
      &nbsp;&middot;&nbsp;
      Written <%= time_ago_in_words(@the_journal.created_at) %> ago
    </p>
  </div>

  <%# ===== AI-Generated Questions ===== %>
  <% if @the_journal.ai_generated_questions.present? %>
    <div class="card border-0 shadow-sm mb-4" style="background:#f8f5ff;">
      <div class="card-body">
        <h6 class="text-uppercase fw-bold text-primary mb-3" style="font-size:0.7rem;letter-spacing:.08em;">
          <i class="fa-solid fa-lightbulb me-1"></i>Reflection Prompts
        </h6>
        <% @the_journal.ai_generated_questions.split("|").each_with_index do |question, i| %>
          <div class="d-flex gap-2 mb-2">
            <span class="badge bg-primary rounded-pill" style="font-size:0.7rem;height:fit-content;padding:.25em .55em;">
              <%= i + 1 %>
            </span>
            <p class="mb-0 small"><%= question.strip %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# ===== Current Response (read view) ===== %>
  <% if @the_journal.response.present? %>
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body">
        <h6 class="text-uppercase fw-bold text-muted mb-2" style="font-size:0.7rem;letter-spacing:.08em;">
          <i class="fa-solid fa-pen-nib me-1"></i>Your Entry
        </h6>
        <p class="mb-0" style="white-space:pre-wrap;line-height:1.7;"><%= @the_journal.response %></p>
      </div>
    </div>
  <% end %>

  <%# ===== Edit Response Form ===== %>
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <h6 class="text-uppercase fw-bold text-muted mb-3" style="font-size:0.7rem;letter-spacing:.08em;">
        <i class="fa-solid fa-pencil me-1"></i><%= @the_journal.response.present? ? "Edit Entry" : "Write Your Entry" %>
      </h6>
      <form action="/modify_journal/<%= @the_journal.id %>" method="post">
        <div class="mb-3">
          <textarea name="query_response"
                    class="form-control"
                    rows="8"
                    placeholder="Write your reflections here…"><%= @the_journal.response %></textarea>
        </div>
        <div class="d-flex justify-content-end">
          <button type="submit" class="btn btn-primary btn-sm">
            <i class="fa-solid fa-floppy-disk me-1"></i>Save Entry
          </button>
        </div>
      </form>
    </div>
  </div>

</div>
